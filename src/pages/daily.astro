---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Daily Devotional"
  description="A daily word from Reverend Edward Adeniji Koye-Ladele — scripture, reflection, and prayer for today."
>

  <section class="bg-forest-900 text-white py-16">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-[var(--color-gold-light)] text-xs tracking-widest uppercase mb-3">Daily Devotional</p>
      <h1 class="font-serif text-5xl md:text-6xl" style="font-family: var(--font-serif)">A Word for Today</h1>
      <p id="devotional-date" class="text-forest-300 mt-4 text-sm"></p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-6 py-16">

    <!-- Loading state -->
    <div id="devotional-loading" class="space-y-6">
      <div class="bg-forest-900 rounded-xl p-8 border-l-4 border-[var(--color-gold)] animate-pulse">
        <div class="h-3 w-24 bg-forest-700 rounded mb-4"></div>
        <div class="h-6 bg-forest-700 rounded mb-2"></div>
        <div class="h-6 w-3/4 bg-forest-700 rounded mb-4"></div>
        <div class="h-3 w-32 bg-forest-800 rounded"></div>
      </div>
      <div class="bg-white rounded-xl p-8 border border-[var(--color-cream-dark)] animate-pulse space-y-3">
        <div class="h-4 bg-gray-100 rounded"></div>
        <div class="h-4 bg-gray-100 rounded"></div>
        <div class="h-4 w-5/6 bg-gray-100 rounded"></div>
        <div class="h-4 bg-gray-100 rounded mt-4"></div>
        <div class="h-4 w-4/6 bg-gray-100 rounded"></div>
      </div>
    </div>

    <!-- Content (hidden until loaded) -->
    <article id="devotional-content" class="space-y-8 hidden">

      <div class="bg-forest-900 rounded-xl p-8 border-l-4 border-[var(--color-gold)]">
        <p class="text-[var(--color-gold-light)] text-xs tracking-widest uppercase mb-4">Today's Scripture</p>
        <blockquote id="scripture-verse" class="font-serif text-xl md:text-2xl text-white leading-relaxed italic mb-4"
          style="font-family: var(--font-serif)"></blockquote>
        <p id="scripture-ref" class="text-forest-400 text-sm font-medium"></p>
      </div>

      <div class="bg-white rounded-xl p-8 shadow-sm border border-[var(--color-cream-dark)]">
        <div id="devotional-text" class="prose prose-lg max-w-none text-forest-800 leading-relaxed space-y-4"></div>
      </div>

      <div class="text-center pt-4">
        <a href="/"
          class="inline-flex items-center gap-2 text-sm text-forest-600 hover:text-forest-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to home
        </a>
      </div>

    </article>

    <!-- Error state (hidden until needed) -->
    <div id="devotional-error" class="hidden text-center py-24">
      <p class="font-serif text-2xl text-forest-800 italic mb-2" style="font-family: var(--font-serif)">
        Daily devotionals coming soon
      </p>
      <p class="text-forest-500 text-sm">Check back shortly.</p>
    </div>

  </div>

  <script>
    (async () => {
      const loading = document.getElementById('devotional-loading')!;
      const content = document.getElementById('devotional-content')!;
      const error = document.getElementById('devotional-error')!;

      try {
        const res = await fetch('/data/devotionals.json');
        if (!res.ok) throw new Error('fetch failed');
        const all: any[] = await res.json();

        const now = new Date();
        const dayOfYear = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000);
        const devotional = all[(dayOfYear - 1) % all.length];

        // Date header
        document.getElementById('devotional-date')!.textContent =
          now.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

        // Scripture
        document.getElementById('scripture-verse')!.textContent = `"${devotional.verse}"`;
        document.getElementById('scripture-ref')!.textContent = `${devotional.reference} — KJV`;

        // Devotional body
        const textEl = document.getElementById('devotional-text')!;
        for (const line of devotional.devotional.split('\n')) {
          if (line.trim() === '') {
            const div = document.createElement('div');
            div.className = 'h-2';
            textEl.appendChild(div);
          } else if (line === line.toUpperCase() && line.trim().length > 3) {
            const p = document.createElement('p');
            p.className = 'font-semibold tracking-wide text-forest-900 text-sm';
            p.textContent = line;
            textEl.appendChild(p);
          } else {
            const p = document.createElement('p');
            p.textContent = line;
            textEl.appendChild(p);
          }
        }

        loading.classList.add('hidden');
        content.classList.remove('hidden');

      } catch {
        loading.classList.add('hidden');
        error.classList.remove('hidden');
      }
    })();
  </script>

</Layout>
