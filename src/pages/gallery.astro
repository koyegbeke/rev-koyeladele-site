---
import Layout from '../layouts/Layout.astro';
import { client, urlFor } from '../lib/sanity';

const rawPhotos = await client.fetch(`
  *[_type == "gallery"][0].photos[] {
    _key,
    image,
    caption,
    date
  }
`).catch(() => null);

const photos = rawPhotos ?? [];
---

<Layout title="Gallery" description="A photographic record of the life and ministry of Reverend Edward Adeniji Koye-Ladele.">

  <section class="bg-forest-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-[var(--color-gold-light)] text-xs tracking-widest uppercase mb-3">In Images</p>
      <h1 class="font-serif text-5xl md:text-6xl" style="font-family: var(--font-serif)">Gallery</h1>
      <p class="text-forest-200 mt-4 max-w-xl">
        Moments from his life and ministry, preserved for those who loved him and those who will come to know him.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-6 py-16">
    {photos.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {photos.map((photo: any, i: number) => (
          <div class="group relative aspect-square bg-forest-100 rounded-lg overflow-hidden">
            <img
              src={urlFor(photo.image).width(400).height(400).fit('crop').url()}
              alt={photo.caption || 'Photo of Rev. Koye-Ladele'}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            {photo.caption && (
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                <p class="text-white text-xs">{photo.caption}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-24">
        <div class="w-24 h-24 mx-auto bg-forest-100 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="font-serif text-2xl text-forest-800 italic mb-3" style="font-family: var(--font-serif)">
          Photos are being gathered
        </p>
        <p class="text-gray-500 text-sm">This gallery will be filled with photographs from his life and ministry.</p>
      </div>
    )}
  </div>

</Layout>
