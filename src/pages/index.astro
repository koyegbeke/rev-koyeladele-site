---
import Layout from '../layouts/Layout.astro';
import SermonCard from '../components/SermonCard.astro';
import { client, urlFor, youtubeIdFrom } from '../lib/sanity';

// Daily devotional — picks by day of year, gracefully absent before generation
let todaysDevotional: any = null;
try {
  const { default: all } = await import('../data/devotionals.json', { assert: { type: 'json' } });
  const now = new Date();
  const dayOfYear = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000);
  todaysDevotional = (all as any[])[(dayOfYear - 1) % all.length];
} catch { /* not yet generated */ }

const settings = await client.fetch(`
  *[_type == "siteSettings"][0] {
    heroImages,
    heroQuote,
    heroQuoteSource
  }
`).catch(() => null);

const heroImageUrls: string[] = (settings?.heroImages ?? []).map((img: any) =>
  urlFor(img).width(700).height(900).fit('crop').url()
);

const rawFeatured = await client.fetch(`
  *[_type == "sermon" && featured == true] | order(date desc) [0...3] {
    _id,
    title,
    "slug": slug.current,
    description,
    youtubeUrl,
    "themes": themes[]->title,
    date,
    duration
  }
`).catch(() => []);

const featuredSermons = rawFeatured.map((s: any) => ({
  slug: s.slug,
  title: s.title,
  description: s.description || '',
  themes: s.themes || [],
  date: s.date || '',
  duration: s.duration || '',
  youtubeId: s.youtubeUrl ? youtubeIdFrom(s.youtubeUrl) : '',
  thumbnailUrl: '',
}));
---

<Layout title="Home">

  <!-- Hero -->
  <section class="relative bg-forest-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10"
      style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');">
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-40">
      <div class="max-w-3xl">
        <p class="text-[var(--color-gold-light)] text-sm tracking-widest uppercase mb-6 font-sans">
          A Legacy of Service and Devotion
        </p>
        <h1 class="text-5xl md:text-7xl font-serif font-semibold text-white leading-tight mb-6"
          style="font-family: var(--font-serif)">
          Reverend Edward Adeniji<br/>
          <span class="text-[var(--color-gold-light)]">Koye-Ladele</span>
        </h1>
        <p class="text-lg md:text-xl text-forest-200 leading-relaxed mb-4 max-w-2xl">
          Minister of the Gospel for three decades. Teacher. Shepherd. Father.
          His sermons carried the Word into thousands of lives — and they still do.
        </p>
        <p class="text-sm text-forest-500 mb-10 tracking-wide">May 17, 1963 — October 14, 2022</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/sermons"
            class="inline-flex items-center justify-center px-8 py-4 bg-[var(--color-gold)] hover:bg-[var(--color-gold-dark)] text-white font-medium rounded transition-colors text-sm tracking-wide">
            Browse the Sermons
          </a>
          <a href="/about"
            class="inline-flex items-center justify-center px-8 py-4 border border-forest-600 hover:border-forest-400 text-forest-200 hover:text-white rounded transition-colors text-sm tracking-wide">
            His Story
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Scripture banner -->
  <section class="bg-[var(--color-gold)] py-6">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <blockquote class="text-white font-serif text-xl md:text-2xl italic" style="font-family: var(--font-serif)">
        "How beautiful are the feet of those who bring good news!"
      </blockquote>
      <p class="text-amber-100 text-sm mt-2">Romans 10:15</p>
    </div>
  </section>

  <!-- Featured Sermons -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-[var(--color-gold)] text-xs tracking-widest uppercase mb-2">Selected Teachings</p>
        <h2 class="font-serif text-4xl text-forest-900" style="font-family: var(--font-serif)">Featured Sermons</h2>
      </div>
      <a href="/sermons" class="hidden md:inline-flex items-center text-sm text-forest-600 hover:text-forest-900 transition-colors gap-2">
        View all sermons
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {featuredSermons.map(sermon => (
        <SermonCard sermon={sermon} />
      ))}
    </div>

    <div class="mt-10 text-center md:hidden">
      <a href="/sermons" class="inline-flex items-center text-sm text-forest-600 hover:text-forest-900 transition-colors gap-2">
        View all sermons →
      </a>
    </div>
  </section>

  <!-- About strip -->
  <section class="bg-forest-800 text-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-[var(--color-gold-light)] text-xs tracking-widest uppercase mb-4">The Man</p>
          <h2 class="font-serif text-4xl md:text-5xl mb-6 leading-tight" style="font-family: var(--font-serif)">
            A life given to the Word
          </h2>
          <p class="text-forest-200 leading-relaxed mb-6">
            Born in Okemesi Ekiti, Reverend Koye-Ladele answered the call to ministry and spent over
            thirty years faithfully preaching, teaching, and shepherding congregations across Nigeria.
            He was known for his gentle authority, his depth of scripture, and his gift for making
            the Gospel feel urgently personal.
          </p>
          <a href="/about"
            class="inline-flex items-center text-[var(--color-gold-light)] hover:text-white transition-colors text-sm gap-2">
            Read his full biography
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div id="hero-carousel" class="relative rounded-lg overflow-hidden border border-forest-700 aspect-[3/4] w-full max-w-sm mx-auto md:max-w-none md:aspect-auto md:min-h-[420px]">
          {heroImageUrls.length > 0 ? (
            <>
              {heroImageUrls.map((url: string, i: number) => (
                <img
                  src={url}
                  alt="Reverend Edward Adeniji Koye-Ladele"
                  class="absolute inset-0 w-full h-full object-cover object-top transition-opacity duration-1000"
                  style={i === 0 ? "opacity:1" : "opacity:0"}
                  data-slide={i}
                />
              ))}
              {heroImageUrls.length > 1 && (
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
                  {heroImageUrls.map((_: string, i: number) => (
                    <button
                      data-dot={i}
                      class="w-2 h-2 rounded-full transition-colors duration-300"
                      style={i === 0 ? "background:white" : "background:rgba(255,255,255,0.35)"}
                      aria-label={`Photo ${i + 1}`}
                    />
                  ))}
                </div>
              )}
            </>
          ) : (
            <div class="absolute inset-0 bg-forest-900 flex items-center justify-center">
              <div class="text-center text-forest-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <p class="text-sm">Photo coming soon</p>
              </div>
            </div>
          )}
        </div>

        <script>
          const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-slide]'));
          const dots = Array.from(document.querySelectorAll<HTMLElement>('[data-dot]'));
          if (slides.length > 1) {
            let current = 0;
            function goTo(n: number) {
              slides[current].style.opacity = '0';
              if (dots[current]) dots[current].style.background = 'rgba(255,255,255,0.35)';
              current = n % slides.length;
              slides[current].style.opacity = '1';
              if (dots[current]) dots[current].style.background = 'white';
            }
            setInterval(() => goTo(current + 1), 5000);
            dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
          }
        </script>
      </div>
    </div>
  </section>

  <!-- Daily Devotional teaser -->
  <section class="bg-forest-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-[var(--color-gold-light)] text-xs tracking-widest uppercase mb-3">Daily Devotional</p>
        <h2 class="font-serif text-4xl md:text-5xl mb-8" style="font-family: var(--font-serif)">A Word for Today</h2>

        {todaysDevotional ? (
          <div class="text-left">
            <div class="border-l-4 border-[var(--color-gold)] pl-6 mb-6">
              <p class="text-[var(--color-gold-light)] text-xs tracking-widest uppercase mb-2">{todaysDevotional.reference} — KJV</p>
              <blockquote class="font-serif text-xl md:text-2xl text-white italic leading-relaxed"
                style="font-family: var(--font-serif)">
                "{todaysDevotional.verse}"
              </blockquote>
            </div>
            <div class="text-forest-200 leading-relaxed space-y-3 mb-8">
              {(() => {
                const lines: string[] = todaysDevotional.devotional.split('\n');
                const preview: string[] = [];
                let wordCount = 0;
                for (const line of lines) {
                  if (wordCount >= 60) break;
                  if (line.trim()) {
                    preview.push(line);
                    wordCount += line.split(' ').length;
                  }
                }
                return preview.map((line: string) => <p>{line}</p>);
              })()}
              <p class="text-forest-400 italic">...</p>
            </div>
            <div class="text-center">
              <a href="/daily"
                class="inline-flex items-center gap-2 px-8 py-4 border border-[var(--color-gold)] text-[var(--color-gold-light)] hover:bg-[var(--color-gold)] hover:text-white rounded transition-colors text-sm tracking-wide">
                Read today's full devotional
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        ) : (
          <div>
            <p class="text-forest-300 italic font-serif text-xl mb-6" style="font-family: var(--font-serif)">
              "The grass withereth, the flower fadeth: but the word of our God shall stand for ever."
            </p>
            <p class="text-forest-400 text-sm mb-8">Isaiah 40:8 — KJV</p>
            <a href="/daily"
              class="inline-flex items-center gap-2 px-8 py-4 border border-forest-600 text-forest-300 hover:border-[var(--color-gold)] hover:text-[var(--color-gold-light)] rounded transition-colors text-sm tracking-wide">
              Daily devotionals coming soon
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Email signup -->
  <section class="bg-[var(--color-cream-dark)] py-20">
    <div class="max-w-xl mx-auto px-6 text-center">
      <p class="text-[var(--color-gold)] text-xs tracking-widest uppercase mb-3">Stay Connected</p>
      <h2 class="font-serif text-3xl md:text-4xl text-forest-900 mb-4" style="font-family: var(--font-serif)">
        A word of encouragement, from time to time
      </h2>
      <p class="text-forest-600 text-sm leading-relaxed mb-8">
        Receive devotionals, reflections, and updates from the ministry — in his memory, for your edification.
      </p>
      <form
        id="subscribe-form"
        action="https://buttondown.email/api/emails/embed-subscribe/revkoyeladele"
        method="post"
        class="flex flex-col sm:flex-row gap-3"
      >
        <input type="hidden" name="embed" value="1" />
        <input
          type="email"
          name="email"
          required
          placeholder="Your email address"
          class="flex-1 px-4 py-3 rounded border border-[var(--color-cream-dark)] bg-white text-forest-900 text-sm placeholder-forest-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)] focus:border-transparent"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-forest-900 hover:bg-forest-800 text-white text-sm font-medium rounded transition-colors whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p id="subscribe-msg" class="mt-4 text-sm text-forest-600 hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('subscribe-form') as HTMLFormElement;
    const msg = document.getElementById('subscribe-msg') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        const res = await fetch(form.action, { method: 'POST', body: data });
        msg.classList.remove('hidden');
        if (res.ok) {
          msg.textContent = 'Thank you — please check your inbox to confirm your subscription.';
          msg.className = 'mt-4 text-sm text-forest-600';
          form.reset();
        } else {
          msg.textContent = 'Something went wrong. Please try again.';
          msg.className = 'mt-4 text-sm text-red-500';
        }
      } catch {
        msg.textContent = 'Something went wrong. Please try again.';
        msg.className = 'mt-4 text-sm text-red-500';
      }
    });
  </script>

  <!-- Reflections (blog) teaser -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-10">
      <p class="text-[var(--color-gold)] text-xs tracking-widest uppercase mb-2">Written Word</p>
      <h2 class="font-serif text-4xl text-forest-900" style="font-family: var(--font-serif)">Reflections</h2>
      <p class="text-forest-600 mt-2 text-sm">Selected messages in written form, with links to the original teaching.</p>
    </div>
    <div class="bg-[var(--color-cream-dark)] rounded-lg p-12 text-center border border-[var(--color-cream-dark)]">
      <p class="text-forest-600 font-serif text-xl italic" style="font-family: var(--font-serif)">
        Reflections are being prepared. Come back soon.
      </p>
    </div>
    <div class="mt-6 text-right">
      <a href="/blog" class="text-sm text-forest-600 hover:text-forest-900 transition-colors">
        Visit the Reflections →
      </a>
    </div>
  </section>

</Layout>
