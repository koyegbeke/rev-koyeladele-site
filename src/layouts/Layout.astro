---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "A legacy of faith, ministry, and the enduring Word of God — the sermons and teachings of Reverend Edward Adeniji Koye-Ladele.",
  image = "/images/og-default.jpg"
} = Astro.props;

const fullTitle = title === "Home"
  ? "Rev. Edward Adeniji Koye-Ladele"
  : `${title} — Rev. Edward Adeniji Koye-Ladele`;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/sermons", label: "Sermons" },
  { href: "/blog", label: "Reflections" },
  { href: "/about", label: "Biography" },
  { href: "/gallery", label: "Gallery" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-cream)]">

    <!-- Navigation -->
    <header class="bg-forest-900 text-white sticky top-0 z-50 shadow-lg">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex flex-col leading-tight group">
          <span class="font-serif text-lg font-semibold text-white group-hover:text-gold-light transition-colors" style="font-family: var(--font-serif)">
            Rev. E. A. Koye-Ladele
          </span>
          <span class="text-xs text-forest-300 tracking-widest uppercase">1963 — 2022</span>
        </a>

        <!-- Desktop nav -->
        <ul class="hidden md:flex items-center gap-8">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`text-sm tracking-wide transition-colors hover:text-[var(--color-gold-light)] ${
                  currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                    ? 'text-[var(--color-gold-light)] border-b border-[var(--color-gold)]'
                    : 'text-forest-200'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="md:hidden text-forest-200 hover:text-white"
          aria-label="Toggle menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-forest-950 border-t border-forest-800">
        <ul class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`block text-sm tracking-wide transition-colors hover:text-[var(--color-gold-light)] ${
                  currentPath === link.href ? 'text-[var(--color-gold-light)]' : 'text-forest-200'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-forest-950 text-forest-300 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <h3 class="font-serif text-2xl text-white mb-3" style="font-family: var(--font-serif)">
              Rev. Edward Adeniji Koye-Ladele
            </h3>
            <p class="text-sm text-forest-400 leading-relaxed">
              Minister of the Gospel. Shepherd. Father. His voice endures.
            </p>
            <p class="text-xs text-forest-600 mt-4 tracking-widest uppercase">May 17, 1963 — October 14, 2022</p>
          </div>

          <div>
            <h4 class="text-xs tracking-widest uppercase text-forest-500 mb-4">Pages</h4>
            <ul class="space-y-2">
              {navLinks.map(link => (
                <li>
                  <a href={link.href} class="text-sm text-forest-400 hover:text-[var(--color-gold-light)] transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h4 class="text-xs tracking-widest uppercase text-forest-500 mb-4">A word</h4>
            <blockquote class="text-sm text-forest-400 italic leading-relaxed border-l-2 border-forest-700 pl-4">
              "The grass withers and the flowers fall, but the word of our God endures forever."
            </blockquote>
            <p class="text-xs text-forest-600 mt-2">Isaiah 40:8</p>
          </div>
        </div>

        <div class="border-t border-forest-900 mt-12 pt-8 text-xs text-forest-600 flex flex-col md:flex-row justify-between gap-2">
          <p>Built in loving memory by his family.</p>
          <p>© {new Date().getFullYear()} Koye-Ladele Family</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
